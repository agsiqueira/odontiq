# AI provider selector. Supported values: mock, navigator.
AI_PROVIDER=mock

# UF Navigator server-side settings. Do not expose these in client components.
NAVIGATOR_API_KEY=
# Optional. Defaults to https://api.ai.it.ufl.edu. Do not include /v1/chat/completions.
NAVIGATOR_BASE=
NAVIGATOR_MODEL=
NAVIGATOR_TTS_MODEL=kokoro
NAVIGATOR_TTS_VOICE=af_heart
NAVIGATOR_TTS_SPEED=1
NAVIGATOR_TTS_TIMEOUT_MS=60000
# Neon/Postgres. Use the pooled URL at runtime and the direct URL for migrations.
DATABASE_URL=
DIRECT_URL=

# Clerk authentication. Configure these in the Clerk Dashboard and deployment environment.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=
